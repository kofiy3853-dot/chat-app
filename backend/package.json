{
  "name": "campus-chat-backend",
  "version": "1.0.0",
  "description": "Campus Chat - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "prisma generate && prisma db push --accept-data-loss",
    "test": "jest",
    "storage:setup": "node scripts/setup-storage.js",
    "db:init": "node scripts/init-db.js",
    "db:diagnose": "node scripts/diagnose.js",
    "db:push": "prisma db push --accept-data-loss",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.33.0",
    "path": "^0.12.7",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "redis": "^4.6.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
